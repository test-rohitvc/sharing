# --- RabbitMQ Connection ---
# The hostname is 'rabbitmq' matching the service name in docker-compose.yml
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//

# --- Email Settings ---
TRIGGER_EMAIL=trigger@bmo.in
TRIGGER_PASSWORD=your_secure_password_here
MAIL_SERVER=10.0.1.90

# --- FileBrowser Settings ---
# Ensure this IP is reachable from INSIDE the Docker container. 
# If FileBrowser is on the host machine, you might need to use host.docker.internal depending on your OS.
FILEBROWSER_URL=http://10.0.1.90:8080
FILEBROWSER_USER=admin
FILEBROWSER_PASS=your_filebrowser_password_here
